---
import DefaultBtn from "@components/_UI/DefaultBtn/DefaultBtn.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Разводящая">
  <div class="wrapper">
    <DefaultBtn component="a" href="./main-page.html">Главная</DefaultBtn>
    <DefaultBtn component="a" href="./about-page.html">О компании</DefaultBtn>
    <DefaultBtn component="a" href="./career-page.html">Карьера</DefaultBtn>
    <DefaultBtn component="a" href="./contacts-page.html">Контакты</DefaultBtn>
    <DefaultBtn component="a" href="./docs-page.html">Документы</DefaultBtn>
    <DefaultBtn component="a" href="./services-page.html">Услуги</DefaultBtn>
  </div>

  <style is:inline>
    .wrapper {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      padding: 14rem 2rem 8rem 2rem;
    }
  </style>
</Layout>
