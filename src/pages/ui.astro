---
import DefaultBtn from "@components/_UI/DefaultBtn/DefaultBtn.astro";
import { Sprite } from "astro-icon";
import Layout from "src/layouts/Layout.astro";
---

<Layout title="UI">
  <div class="wrapper">
    <div class="box">
      <DefaultBtn>
        Text
        <Sprite name="arrow-up-right" />
      </DefaultBtn>
      <DefaultBtn disabled>
        Text
        <Sprite name="arrow-up-right" />
      </DefaultBtn>
    </div>
    <div class="box">
      <DefaultBtn color="secondary">
        Text
        <Sprite name="arrow-up-right" />
      </DefaultBtn>
      <DefaultBtn disabled>
        Text
        <Sprite name="arrow-up-right" />
      </DefaultBtn>
    </div>
    <div class="box">
      <DefaultBtn color="white">
        <Sprite name="menu" />
         Text
      </DefaultBtn>
      <DefaultBtn disabled>
        <Sprite name="menu" />
         Text
      </DefaultBtn>
    </div>
  </div>
</Layout>

<style is:inline>
  .wrapper {
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4rem;
  }
  .box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
  }
</style>
