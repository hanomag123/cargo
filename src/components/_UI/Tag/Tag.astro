---
// @ts-nocheck
import type { IUIButtonAttributes, IUIVariableComponent } from "src/interface";

interface Props
  extends IUIButtonAttributes,
    IUIVariableComponent,
    astroHTML.JSX.ButtonHTMLAttributes {
  variant?: null;
  size?: null;
  color?: null;
}

const {
  component: Wrapper = "span",
  variant,
  size,
  color,
  ...props
} = Astro.props;
---

<Wrapper
  class="tag"
  class:list={[
    {
      ["tag_" + color]: color,
      ["tag_" + variant]: variant,
      ["tag_" + size]: size,
    },
  ]}
  {...props}
>
  <slot />
</Wrapper>
