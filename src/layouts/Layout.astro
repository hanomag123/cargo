---
import "../assets/styles/style.scss";
import { Sprite } from "astro-icon";
import Header from "@components/Header/Header.astro";
import Footer from "@components/Footer/Footer.astro";
import PopupAsk from "@components/Popup/PopupAsk/PopupAsk.astro";
import PopupOrder from "@components/Popup/PopupOrder/PopupOrder.astro";
import PopupDeliv from "@components/Popup/PopupDeliv/PopupDeliv.astro";
import PopupAuth from "@components/Popup/PopupAuth/PopupAuth.astro";
import PopupReg from "@components/Popup/PopupReg/PopupReg.astro";

interface Props {
  title?: string;
}

const { title = "заголовок страницы" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="./favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
  </head>
  <body>
    <Sprite.Provider>
      <Header />
      <main class="page">
        <slot />
      </main>
      <Footer />
    </Sprite.Provider>
  </body>

  <script src="../assets/scripts/index.ts"></script>
</html>
